{


  "ConnectionStrings": {
    "DefaultConnection": "Data Source=VASHU\\SQLSERVERVISHAL;Initial Catalog=ToDoListVK;Integrated Security=True;Connect Timeout=30;Encrypt=False;TrustServerCertificate=True;MultipleActiveResultSets=True; "

    // "DefaultConnection": "Server=VASHU\\SQLSERVERVISHAL;Database=TodolistVSDB;Trusted_Connection=True;Encrypt=False;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}

//1️⃣ Data Source=(localdb)\MSSQLLocalDB
//👉 SQL Server LocalDB instance use ho rahi hai (mostly Visual Studio ke sath aati hai)

//2️⃣ Initial Catalog=ToDoList
//👉 Database ka name: ToDoList
//👉 Agar database exist nahi karta → migration se create hoga

//3️⃣ Integrated Security=True
//👉 Windows Authentication use hoga
//👉 Username / Password ki zarurat nahi

//4️⃣ Connect Timeout=30
//👉 30 seconds tak connection ka wait karega

//5️⃣ Encrypt=False
//👉 Data encryption off hai (LocalDB me ok hota hai)

//6️⃣ Trust Server Certificate=True
//👉 SSL certificate verify skip karega

//7️⃣ MultipleActiveResultSets=True (MARS)
//👉 Ek hi connection par multiple queries ek sath run ho sakti hain
//👉 EF Core ke liye useful