@model TodolistTashkVS.ViewModels.TodoListViewModel

@{
    ViewData["Title"] = "Delete Task";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card shadow-lg border-0 rounded-4">
            <div class="card-header bg-danger text-white rounded-top-4 p-4">
                <h3 class="mb-0 fw-bold">Delete Task</h3>
            </div>

            <div class="card-body p-4">
                <h5 class="mb-3">Are you sure you want to delete this task?</h5>

                <div class="mb-3">
                    <label class="fw-semibold">Title</label>
                    <div class="form-control rounded-3 bg-light">@Model.Title</div>
                </div>

                <div class="mb-4">
                    <label class="fw-semibold">Description</label>
                    <div class="form-control rounded-3 bg-light" style="min-height:100px;">@Model.Description</div>
                </div>

                <form asp-action="Delete" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />

                    <button type="submit" class="btn btn-danger px-4 rounded-3">
                        <i class="fa-solid fa-trash me-2"></i>Delete
                    </button>

                    <a asp-action="Index" class="btn btn-secondary px-4 rounded-3">
                        <i class="fa-solid fa-arrow-left me-2"></i>Cancel
                    </a>
                </form>
            </div>
        </div>
    </div>
</div>