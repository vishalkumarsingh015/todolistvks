@using TodolistTashkVS.ViewModels
@model CreateViewModels

@{
    ViewData["Title"] = "Create";
}

<div class="container vh-100 d-flex justify-content-center align-items-center">
    <div class="col-md-6">
        <div class="card shadow-lg border-0 rounded-4">

            <div class="card-header bg-primary text-white text-center rounded-top-4">
                <h4 class="mb-0">Create Todo Task</h4>
            </div>

            <div class="card-body p-4">
                <form asp-action="Create" method="post">

                    <!-- Validation Summary -->
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <!-- Title -->
                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-semibold"></label>
                   
                        <input asp-for="Title"
                               class="form-control form-control-lg shadow-sm"
                               placeholder="Enter task title" />

                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <!-- Description -->
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold"></label>

                        <textarea asp-for="Description"
                                  class="form-control"
                                  rows="4"
                                  placeholder="Enter task description"></textarea>

                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <!-- Buttons -->
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-lg w-50">
                            Submit
                        </button>

                        <a asp-action="Index" class="btn btn-secondary btn-lg w-50">
                            Back
                        </a>
                    </div>

                </form>
            </div>

            <div class="card-footer text-center text-muted small">
                Todo Management System VKS
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
