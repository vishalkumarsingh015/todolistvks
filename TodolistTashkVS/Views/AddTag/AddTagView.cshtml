@model List<TodolistTashkVS.ViewModels.AddTagViewModel>

@{
    ViewData["Title"] = "Tag List";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
       
        <a asp-action="Create" asp-controller="AddTag"
           asp-route-todoListId="@ViewBag.TodoListId" class="btn btn-primary">+ Add New Tag</a>
        <h2 class="fw-bold">Tag List</h2>
        <a asp-action="Details"
           asp-controller="Tasks"
           asp-route-todolistId="@ViewBag.TodoListId"
           class="btn btn-secondary">
            Back
        </a>
    </div>
    

    @if (TempData["success"] != null)
    {
        <div class="alert alert-success">
            @TempData["success"]
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Id</th>
                        <th>Name</th>
                        <th>Color</th>
                        <th>Preview</th>
                        <th class="text-center">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>@item.Name</td>
                                <td>@item.Color</td>
                                <td>
                                    <span class="badge px-3 py-2" style="background-color:@item.Color">
                                        @item.Name
                                    </span>
                                </td>
                                <td class="text-center">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning me-1">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted">No tags found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>