@model TodolistTashkVS.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Admin Login";
}

<div class="container-fluid min-vh-100">
    <div class="row min-vh-100">

        <!-- Left Branding Section -->
        <div class="col-lg-6 d-none d-lg-flex align-items-center justify-content-center text-white position-relative"
             style="background: linear-gradient(135deg, #0d6efd, #6610f2);">

            <div class="text-center px-5">
                <h1 class="fw-bold display-5 mb-3">Welcome Back</h1>
                <p class="lead mb-4">
                    Secure admin access for your Todo Management System.
                </p>

                <div class="bg-white bg-opacity-10 rounded-5 p-5 shadow-sm">
                    <h4 class="fw-semibold mb-3">Why sign in?</h4>
                    <p class="mb-2">✔ Manage your tasks securely</p>
                    <p class="mb-2">✔ Access protected admin features</p>
                    <p class="mb-0">✔ Fast, clean and production-ready workflow</p>
                </div>
            </div>
        </div>

        <!-- Right Login Section -->
        <div class="col-lg-6 d-flex align-items-center justify-content-center bg-light">
            <div class="card shadow-lg border-0 rounded-4 p-4 p-md-5 login-card-hover" style="width:100%; max-width:450px;">

                <div class="text-center mb-4">
                    <h2 class="fw-bold text-primary">Admin Login</h2>
                    <p class="text-muted mb-0">Enter your credentials to continue</p>
                </div>

                <form asp-action="Login" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="ReturnUrl" type="hidden" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <!-- Email -->
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold"></label>
                        <input asp-for="Email"
                               class="form-control form-control-lg rounded-3"
                               placeholder="Enter your email" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <!-- Password -->
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label fw-semibold"></label>
                        <input asp-for="Password"
                               class="form-control form-control-lg rounded-3"
                               placeholder="Enter your password" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <!-- Remember / Forgot -->
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label"></label>
                        </div>

                        <a href="#" class="text-decoration-none small">Forgot Password?</a>
                    </div>

                    <!-- Button -->
                    <div class="d-grid mb-3">
                        <button type="submit" class="btn btn-primary btn-lg rounded-3 shadow-sm">
                            Login
                        </button>
                    </div>

                    <div class="text-center">
                        <span class="text-muted">Don't have an account?</span>
                        <a asp-controller="Account" asp-action="Register" class="text-decoration-none fw-semibold">
                            Register
                        </a>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}