@model TodolistTashkVS.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Register";
}

<div class="container-fluid min-vh-100">
    <div class="row min-vh-100">

        <!-- Left Branding Section -->
        <div class="col-lg-6 d-none d-lg-flex align-items-center justify-content-center text-white position-relative"
             style="background: linear-gradient(135deg, #198754, #0d6efd);">

            <div class="text-center px-5">
                <h1 class="fw-bold display-5 mb-3">Create Account</h1>
                <p class="lead mb-4">
                    Join your Todo Management System and start managing work smartly.
                </p>

                <div class="bg-white bg-opacity-10 rounded-4 p-4 shadow-sm">
                    <h4 class="fw-semibold mb-3">Why register?</h4>
                    <p class="mb-2">✔ Create and manage your personal tasks</p>
                    <p class="mb-2">✔ Access secure user features</p>
                    <p class="mb-0">✔ Clean, simple and production-ready workflow</p>
                </div>
            </div>
        </div>

        <!-- Right Register Section -->
        <div class="col-lg-6 d-flex align-items-center justify-content-center bg-light">
            <div class="card shadow-lg border-0 rounded-4 p-4 p-md-5 login-card-hover" style="width:100%; max-width:450px;">

                <div class="text-center mb-4">
                    <h2 class="fw-bold text-success">Register</h2>
                    <p class="text-muted mb-0">Create your account to continue</p>
                </div>

                <form asp-action="Register" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <!-- Name -->
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold"></label>
                        <input asp-for="Name"
                               class="form-control form-control-lg rounded-3"
                               placeholder="Enter your name" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <!-- Email -->
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold"></label>
                        <input asp-for="Email"
                               class="form-control form-control-lg rounded-3"
                               placeholder="Enter your email" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <!-- Password -->
                    <div class="mb-4">
                        <label asp-for="Password" class="form-label fw-semibold"></label>
                        <input asp-for="Password"
                               class="form-control form-control-lg rounded-3"
                               placeholder="Enter your password" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <!-- Confirm Password -->
                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                        <input asp-for="ConfirmPassword"
                               class="form-control form-control-lg rounded-3"
                               placeholder="Confirm your password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>
                    <!-- Button -->
                    <div class="d-grid mb-3">
                        <button type="submit" class="btn btn-success btn-lg rounded-3 shadow-sm">
                            Register
                        </button>
                    </div>

                    <div class="text-center">
                        <span class="text-muted">Already have an account?</span>
                        <a asp-controller="Account" asp-action="Login" class="text-decoration-none fw-semibold">
                            Login
                        </a>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}