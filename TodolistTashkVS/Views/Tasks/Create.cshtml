@using TodolistTashkVS.ViewModels
@using TodolistTashkVS.Models
@model CreateTasksViewModel

@{
    ViewData["Title"] = "Create New Task";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0 rounded-4 create-task-card">
                <div class="card-header bg-primary text-white text-center rounded-top-4">
                    <h4 class="mb-0">✨ Create New Task</h4>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <input type="hidden" asp-for="TodoListId" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="Title" class="form-label fw-semibold text-primary"></label>
                            <input asp-for="Title" class="form-control form-control-lg rounded-3" placeholder="Enter task title" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-semibold text-primary"></label>
                            <textarea asp-for="Description" class="form-control rounded-3" rows="4" placeholder="Enter task description"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Status" class="form-label fw-semibold text-primary"></label>
                                <select asp-for="Status" asp-items="@Html.GetEnumSelectList<Status>()" class="form-select rounded-3">
                                    <option value="">-- Select Status --</option>
                                </select>
                                <span asp-validation-for="Status" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Priority" class="form-label fw-semibold text-primary"></label>
                                <select asp-for="Priority" asp-items="@Html.GetEnumSelectList<Priority>()" class="form-select rounded-3">
                                    <option value="">-- Select Priority --</option>
                                </select>
                                <span asp-validation-for="Priority" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="DueDate" class="form-label fw-semibold text-primary"></label>
                            <input asp-for="DueDate" type="datetime-local" class="form-control rounded-3" />
                            <span asp-validation-for="DueDate" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2 justify-content-center mt-4">
                            <button type="submit" class="btn btn-primary px-4 py-2 shadow-sm">Save</button>
                            <a asp-action="Index" asp-controller="Todo" class="btn btn-outline-secondary px-4 py-2">Back</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .create-task-card {
        transition: all 0.3s ease;
    }

        .create-task-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 24px rgba(0,0,0,0.12);
        }

    .form-control:focus,
    .form-select:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.15rem rgba(13, 110, 253, 0.2);
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}